# Copy this file to .env.local for local development and fill in real values.
# NEVER commit .env* files with real values — they're already git-ignored.
# In production (Vercel), set these under Project Settings → Environment Variables
# instead of committing them anywhere.

# ── Required at runtime (app won't build/boot correctly without these) ──

# Supabase project URL and anon (public) key.
# Dashboard → Project Settings → API. Safe to expose to the browser — RLS
# policies are what actually protect data, not secrecy of these values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service_role key. Bypasses RLS entirely — server-side only, never
# prefix with NEXT_PUBLIC_, never send to the client, never log it.
# Used by createAdminClient() in src/lib/supabase/server.ts, which every
# privileged 'use server' action must gate behind requireAdmin() first.
# Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Optional ──

# Overrides the auto-detected request origin (protocol + host) used to build
# password-reset redirect links (src/app/auth/actions.ts). Only needed if
# the app sits behind a proxy/CDN that doesn't forward x-forwarded-host, or
# once a custom domain is configured and you want it to take priority over
# whatever host header Vercel forwards.
# NEXT_PUBLIC_SITE_URL=https://your-custom-domain.com

# ── Test-only (used by src/lib/supabase/submit-exam-attempt.integration.test.ts) ──
# Point these at a LOCAL Supabase instance only (`supabase start`), never at
# production — this test suite creates/deletes real rows via service_role.
# These are not read by the app itself, only by `npm test`.
# TEST_SUPABASE_URL=http://127.0.0.1:54321
# TEST_SUPABASE_ANON_KEY=local-anon-key-from-supabase-status
# TEST_SUPABASE_SERVICE_ROLE_KEY=local-service-role-key-from-supabase-status
